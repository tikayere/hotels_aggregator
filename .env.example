# Central Hospitality Platform (Service B) -- local/dev environment template.
# Copy to .env and fill in real values. Never commit a filled-in .env.

# --- Core service ---
ENVIRONMENT=development
API_VERSION=v1
LOG_LEVEL=info

# --- PostgreSQL (primary store, section 3.3 / 3.4) ---
DATABASE_URL=postgresql+asyncpg://aggregator:aggregator@localhost:5432/hotel_aggregator

# --- Redis (caching, queues, hold-TTL tracking, section 3.3) ---
REDIS_URL=redis://localhost:6379/0

# --- OpenSearch (search index, section 3.3) ---
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=change-me

# --- Application-layer secret encryption for hotel_credential columns ---
# (see app/db/models.py -- api_key_encrypted / webhook_secret_encrypted are
# ciphertext produced with this key, e.g. via `cryptography.fernet.Fernet`)
CREDENTIAL_ENCRYPTION_KEY=

# --- Webhook receiver (contract section 4.2 / 4.6) ---
WEBHOOK_SIGNATURE_HEADER=X-Hotel-Signature
WEBHOOK_TIMESTAMP_HEADER=X-Hotel-Timestamp
WEBHOOK_REPLAY_WINDOW_SECONDS=300

# --- Payment gateway (FR-B5) -- fill in per chosen provider ---
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_WEBHOOK_SECRET=

# --- Sync Engine cadence (section 3.3) ---
RECONCILIATION_POLL_INTERVAL_SECONDS=900
RECONCILIATION_FULL_RESYNC_CRON=0 2 * * *
HOTEL_HEALTH_POLL_INTERVAL_SECONDS=60

# --- Object storage / CDN for hotel & room-type photos (section 3.3) ---
PHOTO_CDN_BASE_URL=

# --- Rate limiting Service B applies to itself when calling any Hotel ERP ---
# (a courtesy limit so this Aggregator never trips a hotel's own 300 req/min
# limit from contract section 4.11)
OUTBOUND_CALLS_PER_HOTEL_PER_MINUTE=250
